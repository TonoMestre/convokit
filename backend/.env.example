# Anthropic API key used for deliverable generation (Claude API).
ANTHROPIC_API_KEY=

# Path to the SQLite database file. On Railway this points to the mounted volume.
DB_PATH=

# Resend API key for sending result emails to evaluator users.
RESEND_API_KEY=

# From address used in Resend emails. Falls back to a default if unset.
# Example: Innóvate 4.0 <hola@innovate40.es>
RESEND_FROM_EMAIL=

# Inbox that receives internal lead notifications from /submit-evaluation.
EVALUATOR_INTERNAL_EMAIL=

# Optional reply-to address for evaluator emails (internal + client).
EVALUATOR_REPLY_TO_EMAIL=

# Public URL of this backend (used by the evaluador HTML to call /send-result-email
# and /submit-evaluation).
# Example: https://convokit-backend.up.railway.app
BACKEND_URL=
